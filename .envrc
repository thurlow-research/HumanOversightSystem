# direnv configuration for HOS Worker role
# Run: direnv allow   (once, after cloning)
#
# This file is loaded automatically when you cd into this directory.
# It adds bin/ to PATH (making hos-worker, hos-overseer available as commands)
# and sets HOS_CONFIG_DIR to the project-level config location.

PATH_add bin

# Project-level config: ~/Code/<Project>/.config/hos/apps.env
# Keys and App IDs live here — never committed to git.
# See docs/MACHINE-ACCOUNTS-SETUP.md for setup instructions.
export HOS_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/.config/hos"
