#!/usr/bin/env bash
# bin/hos-overseer-cron — cron overseer launcher
#
# Preflight + auth + one oversight cycle via claude --print, then exits.
#
# Cron entry (overseer at :07/:22/:37/:52, offset from worker):
#   7,22,37,52 * * * * /path/to/repo/bin/hos-overseer-cron

set -euo pipefail
REPO_ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel)"
LOG_PREFIX="[hos-overseer-cron] $(date -u '+%Y-%m-%dT%H:%M:%SZ')"

sleep $((RANDOM % 60))

export HOS_REQUIRE_PREFLIGHT=1
bash "$REPO_ROOT/bootstrap/validate_setup.sh" --repo "$REPO_ROOT" --quiet \
  || { echo "$LOG_PREFIX PREFLIGHT FAILED — not starting"; exit 0; }

source <("$REPO_ROOT/bootstrap/get_app_token.sh" --app overseer 2>/dev/null) \
  || { echo "$LOG_PREFIX AUTH FAILED — not starting"; exit 0; }
# #696: read expected login from apps.env, not hardcoded to HOS repo bot name
EXPECTED_LOGIN="${HOS_OVERSEER_BOT_LOGIN:-}"
[[ -n "$EXPECTED_LOGIN" ]] \
  || { echo "$LOG_PREFIX IDENTITY GUARD FAILED: HOS_OVERSEER_BOT_LOGIN not set in apps.env"; exit 1; }
[[ "$HOS_BOT_LOGIN" == "$EXPECTED_LOGIN" ]] \
  || { echo "$LOG_PREFIX IDENTITY GUARD FAILED: got=$HOS_BOT_LOGIN expected=$EXPECTED_LOGIN"; exit 1; }

echo "$LOG_PREFIX Authenticated as $HOS_BOT_LOGIN — starting oversight cycle"

exec claude --print "$(cat "$REPO_ROOT/bootstrap/overseer-cron-prompt.md" 2>/dev/null \
  || echo '---\n**Role: HOS Overseer Agent | autonomous cron invocation**\nReview open PRs.')"
