#!/usr/bin/env bash
# bin/hos-worker-cron — cron worker launcher
#
# Cron entry (every 5 minutes — wakeup/backoff handles idle suppression):
#   */5 * * * * /path/to/repo/bin/hos-worker-cron

set -euo pipefail
REPO_ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel)"
LOG_PREFIX="[hos-worker-cron] $(date -u '+%Y-%m-%dT%H:%M:%SZ')"

_HOS_DIR="${HOS_STATE_DIR:-${HOME}/.hos}"
_WAKEUP_FILE="$_HOS_DIR/wakeup/worker"
_LAST_RUN_FILE="$_HOS_DIR/last-run/worker"
IDLE_INTERVAL="${HOS_WORKER_IDLE_INTERVAL:-1800}"
mkdir -p "$_HOS_DIR/wakeup" "$_HOS_DIR/last-run"

_audit() {
  local event="$1"; shift
  (cd "$REPO_ROOT" && python3 -m scripts.automation.lib.cycle_log "$event" "$@") 2>/dev/null || true
}

sleep $((RANDOM % 60))

if [[ -f "$_WAKEUP_FILE" ]]; then
  # #712: path as argv, not interpolated into Python source
  _wakeup_reason=$(python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    print(d.get('reason', 'unknown'))
except Exception:
    print('unknown')
" "$_WAKEUP_FILE" 2>/dev/null || echo "unknown")
  rm -f "$_WAKEUP_FILE"
  echo "$LOG_PREFIX wakeup signal received (reason=$_wakeup_reason) — running immediately"
  _audit cycle-wakeup "reason=$_wakeup_reason"
elif [[ -f "$_LAST_RUN_FILE" ]]; then
  _last=$(cat "$_LAST_RUN_FILE" 2>/dev/null || echo 0)
  _now=$(date +%s)
  _elapsed=$(( _now - _last ))
  if [[ "$_elapsed" -lt "$IDLE_INTERVAL" ]]; then
    echo "$LOG_PREFIX idle backoff — last run ${_elapsed}s ago (threshold ${IDLE_INTERVAL}s) — skipping"
    exit 0
  fi
  echo "$LOG_PREFIX idle poll — ${_elapsed}s since last run"
fi
# #711: timestamp written only after successful Claude exit

export HOS_REQUIRE_PREFLIGHT=1
if ! bash "$REPO_ROOT/bootstrap/validate_setup.sh" --repo "$REPO_ROOT" --quiet 2>/dev/null; then
  echo "$LOG_PREFIX PREFLIGHT FAILED — not starting loop"
  _audit cycle-preflight-fail reason=validate_setup_failed
  exit 0
fi

# Temp-file pattern — source <() is unreliable in minimal cron environments
# (process substitution requires /dev/fd which may be absent). See hos_worker.sh.
_auth_tmp=$(mktemp)
if ! "$REPO_ROOT/bootstrap/get_app_token.sh" --app worker > "$_auth_tmp" 2>/dev/null; then
  rm -f "$_auth_tmp"
  echo "$LOG_PREFIX AUTH FAILED — not starting loop"
  _audit cycle-preflight-fail reason=auth_failed
  exit 0
fi
source "$_auth_tmp"; rm -f "$_auth_tmp"

if [[ -z "${HOS_EXPECTED_BOT_LOGIN:-}" ]]; then
  echo "$LOG_PREFIX IDENTITY GUARD FAILED: HOS_EXPECTED_BOT_LOGIN not set"
  _audit cycle-preflight-fail "reason=identity_guard_expected_unset"
  exit 1
fi
if [[ "$HOS_BOT_LOGIN" != "$HOS_EXPECTED_BOT_LOGIN" ]]; then
  echo "$LOG_PREFIX IDENTITY GUARD FAILED: got=$HOS_BOT_LOGIN expected=$HOS_EXPECTED_BOT_LOGIN"
  _audit cycle-preflight-fail "reason=identity_guard_mismatch"
  exit 1
fi

# #701: inner-loop test gate
if ! bash "$REPO_ROOT/scripts/framework/run_tests_inner_loop.sh" -q 2>/dev/null; then
  echo "$LOG_PREFIX INNER-LOOP TESTS FAILED — not starting loop (fix test failures first)"
  _audit cycle-preflight-fail reason=inner_loop_tests_failed
  exit 1
fi

_audit cycle-start "bot=$HOS_BOT_LOGIN"
echo "$LOG_PREFIX Authenticated as $HOS_BOT_LOGIN — starting loop"

# #916: capture the real exit code. Under `set -euo pipefail` a bare failing
# `claude` aborts the script before `$?` is read, so the last-run guard and the
# overseer wakeup below never run on a failed session — breaking the two-agent
# handoff on exactly the cycles that most need oversight. Guard with
# `|| _claude_exit=$?`; sibling hos-cron uses the same pattern.
_claude_exit=0
claude --print "$(cat "$REPO_ROOT/bootstrap/worker-cron-prompt.md" 2>/dev/null \
  || echo '---\n**Role: HOS Worker Agent | autonomous cron invocation**\nRun the LOOP.')" \
  || _claude_exit=$?

if [[ $_claude_exit -ne 0 ]]; then
  echo "$LOG_PREFIX claude exited $_claude_exit — if auth-related, refresh the token"
  _audit cycle-claude-fail "exit=$_claude_exit"
fi

# #711: write last-run only on clean exit
if [[ $_claude_exit -eq 0 ]]; then
  date +%s > "$_LAST_RUN_FILE"
fi

# #628: signal overseer — dropped unconditionally (outside the success-only path)
# so the handoff fires even when the worker session failed (#916).
printf '{"reason":"worker-cycle-complete","timestamp":"%s"}\n' \
  "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" > "$_HOS_DIR/wakeup/overseer"
echo "$LOG_PREFIX cycle complete (exit=$_claude_exit) — overseer wakeup signal dropped"
