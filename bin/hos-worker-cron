#!/usr/bin/env bash
# bin/hos-worker-cron — cron worker launcher
#
# Preflight + auth + one LOOP iteration via claude --print, then exits.
# This is the script the OS cron entry calls directly by path.
# Cron does not have direnv PATH, so reference by absolute path.
#
# Cron entry (worker at :00/:15/:30/:45, with jitter):
#   0,15,30,45 * * * * /path/to/repo/bin/hos-worker-cron
#
# Adds jitter (up to 60s) to spread load within each 15-min window.

set -euo pipefail
REPO_ROOT="$(git -C "$(dirname "$0")/.." rev-parse --show-toplevel)"
LOG_PREFIX="[hos-worker-cron] $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
AUDIT_LOG="$REPO_ROOT/audit/oversight-log.jsonl"
NOW="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

# ── Audit helper ──────────────────────────────────────────────────────────────
_audit() {
  local event="$1" extra="${2:-}"
  local entry="{\"event\":\"$event\",\"role\":\"worker\",\"timestamp\":\"$NOW\""
  [[ -n "$extra" ]] && entry="$entry,$extra"
  entry="$entry}"
  echo "$entry" >> "$AUDIT_LOG" 2>/dev/null || true
}

# Jitter — spread runs within the window to avoid thundering herd
sleep $((RANDOM % 60))

# Preflight — zero token cost if setup is broken
export HOS_REQUIRE_PREFLIGHT=1
if ! bash "$REPO_ROOT/bootstrap/validate_setup.sh" --repo "$REPO_ROOT" --quiet 2>/dev/null; then
  echo "$LOG_PREFIX PREFLIGHT FAILED — not starting loop"
  _audit "cycle-preflight-fail" "\"reason\":\"validate_setup failed\""
  exit 0
fi

# Auth
if ! source <("$REPO_ROOT/bootstrap/get_app_token.sh" --app worker 2>/dev/null); then
  echo "$LOG_PREFIX AUTH FAILED — not starting loop"
  _audit "cycle-preflight-fail" "\"reason\":\"auth failed\""
  exit 0
fi

if [[ "$HOS_BOT_LOGIN" != "hos-worker-hos[bot]" ]]; then
  echo "$LOG_PREFIX IDENTITY GUARD FAILED: $HOS_BOT_LOGIN"
  _audit "cycle-preflight-fail" "\"reason\":\"identity guard: $HOS_BOT_LOGIN\""
  exit 0
fi

# Log cycle start
_audit "cycle-start" "\"bot\":\"$HOS_BOT_LOGIN\""
echo "$LOG_PREFIX Authenticated as $HOS_BOT_LOGIN — starting loop"

# Run one LOOP iteration — Claude logs cycle-stop/pick/pr-opened from within the session
exec claude --print "$(cat "$REPO_ROOT/bootstrap/worker-cron-prompt.md" 2>/dev/null \
  || echo '---\n**Role: HOS Worker Agent | autonomous cron invocation**\nRun the LOOP.')"
