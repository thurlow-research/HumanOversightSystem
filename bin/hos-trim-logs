#!/usr/bin/env bash
# bin/hos-trim-logs — trim HOS cron agent logs to prevent unbounded growth
#
# Trims each log to the last HOS_LOG_MAX_LINES lines (default: 10000).
# Idempotent — safe when logs don't exist yet.
#
# Crontab entry (weekly, Sunday 2am):
#   0 2 * * 0  /path/to/bin/hos-trim-logs

set -euo pipefail

MAX_LINES="${HOS_LOG_MAX_LINES:-10000}"

LOGS=(
  /tmp/hos-worker-hos.log
  /tmp/hos-overseer-hos.log
  /tmp/hos-worker-cps.log
  /tmp/hos-overseer-cps.log
)

for log in "${LOGS[@]}"; do
  [[ -f "$log" ]] || continue
  _lines=$(wc -l < "$log")
  if [[ "$_lines" -gt "$MAX_LINES" ]]; then
    tail -n "$MAX_LINES" "$log" > "$log.tmp" && mv "$log.tmp" "$log"
    echo "hos-trim-logs: trimmed $log ($_lines → $MAX_LINES lines)"
  fi
done
