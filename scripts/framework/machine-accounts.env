# Machine-account identity + authority config (AGENT-IDENTITY.md §7) — sourced by
# the server-side enforcement (require_human_approval.py) and the setup tooling.
#
# This file is hosting-AGNOSTIC: it works for a personal repo + collaborators
# (the default) or a GitHub org + team, because it identifies the bots by their
# usernames rather than assuming a team. A consumer copies this and fills in
# their own bot usernames.

# ── Bot accounts (the two identity classes, §7) ───────────────────────────────
# GitHub USERNAMES of the machine accounts. NOTE: these are usernames, not the
# login emails (GitHub usernames cannot contain underscores). The HOS accounts'
# emails are hos_worker@tutelare.ai (worker) and hos_oversight@tutelare.ai
# (overseer); set the corresponding GitHub HANDLES below once confirmed.
#
# An approval counts as a HUMAN approval iff the approver's login is NOT in
# BOT_ACCOUNTS. While BOT_ACCOUNTS is empty/unset the gate degrades safely: it
# still requires *an* approval on a protected surface — it just can't yet exclude
# bot approvals. Populate this the moment the bot handles exist.
BOT_WORKER_USERNAME="HOSWorkerTutelare"      # confirmed GitHub handle for hos_worker@tutelare.ai
BOT_OVERSEER_USERNAME="HOSOversightTutelare" # confirmed GitHub handle for hos_oversight@tutelare.ai
# copilot[bot] is GitHub's native AI reviewer. Its APPROVED review is advisory only and MUST NOT
# satisfy the human-approval gate — so it is a BOT identity here, never counted as human.
COPILOT_BOT_LOGIN="copilot[bot]"
# Space-separated set the status check treats as "bot, not human":
BOT_ACCOUNTS="${BOT_WORKER_USERNAME} ${BOT_OVERSEER_USERNAME} ${COPILOT_BOT_LOGIN}"

# ── Overseer auto-approve ceiling (§7 trust ratchet, #167) ────────────────────
# The highest validated risk tier the OVERSEER bot may auto-approve + merge
# end-to-end. Above this, a HUMAN approval is required (server-side). Starts LOW;
# raise to MEDIUM later by a deliberate human decision — flip this ONE value.
# Never HIGH: high-risk PRs keep a human approver by design.
# OVERSEER_CEILING options: LOW (default) | MEDIUM (never HIGH/CRITICAL)
OVERSEER_CEILING="LOW"
# Status check name the merge_authority.py gate detection looks for
TIER_CEILING_CHECK_NAME="require-tier-ceiling"

# ── Human reviewer identity (OM §1, #222) ────────────────────────────────────
# GitHub login of the human who receives reviewer-request on CONDITIONAL_PROCEED
# PRs. Read by oversight-orchestrator.md when posting REQUEST_CHANGES threads.
# Fail-closed if absent: the orchestrator must not skip the reviewer request.
HUMAN_REVIEWER="ScottThurlow"
